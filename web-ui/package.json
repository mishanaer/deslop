{
  "name": "@deslop/web-ui",
  "version": "0.1.0",
  "description": "React components for Deslop web products, based on shadcn/ui.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./styles.css": "./dist/styles.css",
    "./components/*": "./dist/components/ui/*.js",
    "./blocks/*": "./dist/blocks/*.js",
    "./charts/*": "./dist/charts/*.js"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "check:primitives": "node scripts/check-primitives.mjs",
    "dev": "vite --port 3100",
    "storybook": "vite --port 3100",
    "build": "pnpm build:storybook && pnpm build:lib",
    "build:storybook": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm check:primitives && pnpm typecheck && pnpm build:storybook && pnpm build:lib",
    "preview": "vite preview --port 3100"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@deslop/primitives": "link:../primitives",
    "@hookform/resolvers": "^5.4.0",
    "@shadcn/react": "^0.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.4",
    "react-day-picker": "^10.0.1",
    "react-hook-form": "^7.82.0",
    "react-resizable-panels": "^4.12.2",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "vite-plugin-svgr": "^5.2.0"
  }
}
