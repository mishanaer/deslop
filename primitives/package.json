{
  "name": "@deslop/primitives",
  "version": "0.1.0",
  "private": true,
  "description": "Design tokens, fonts, and icons shared by Deslop component libraries.",
  "type": "module",
  "scripts": {
    "tokens:generate": "node ./scripts/generate-layout-tokens.mjs",
    "tokens:check": "node ./scripts/generate-layout-tokens.mjs --check",
    "colors:check": "node ./scripts/check-color-tokens.mjs",
    "typography:check": "node ./scripts/check-typography-tokens.mjs",
    "icons:check": "node ./scripts/check-icons.mjs",
    "check": "node ./scripts/generate-layout-tokens.mjs --check && node ./scripts/check-color-tokens.mjs && node ./scripts/check-typography-tokens.mjs && node ./scripts/check-icons.mjs"
  }
}
